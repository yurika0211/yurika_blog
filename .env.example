# Blog Stack Environment Template
# Usage:
#   cp .env.example .env
#   edit .env and fill secrets

# ---------- Database (required) ----------
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=postgres

# ---------- Frontend (build args / runtime) ----------
# Used when building the frontend image in docker-compose.yml
VITE_API_BASE_URL=http://localhost:3001/api
VITE_CHAT_API_BASE_URL=http://localhost:8080/api/v1

# Host port -> frontend container port 80 (docker-compose.yml)
FRONTEND_PORT=3000

# Local Vite dev proxy target (frontend/vite.config.ts)
VITE_CHAT_PROXY_TARGET=http://127.0.0.1:8080

# ---------- Chat AI (required) ----------
# Make sure OPENAI_API_URL and OPENAI_MODEL match the same provider.
# OpenAI example:
#   OPENAI_API_URL=https://api.openai.com/v1/chat/completions
#   OPENAI_MODEL=gpt-4o-mini
# DeepSeek example:
#   OPENAI_API_URL=https://api.deepseek.com/chat/completions
#   OPENAI_MODEL=deepseek-chat
OPENAI_API_KEY=<YOUR_LLM_API_KEY>
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini
SYSTEM_CONTENT="You are a helpful AI assistant."
CHAT_PORT=8080

# ---------- RAG (optional) ----------
RAG_ENABLED=false
RAG_WRITE_ENABLED=true
OPENAI_EMBEDDING_URL=https://api.openai.com/v1/embeddings
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=6

# ---------- Memory nudge (optional) ----------
MEMORY_NUDGE_ENABLED=true
MEMORY_NUDGE_PROB=0.20
MEMORY_NUDGE_COOLDOWN_TURNS=5
MEMORY_NUDGE_EXCLUDE_RECENT=8
MEMORY_NUDGE_MAX_CHARS=160
