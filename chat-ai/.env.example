OPENAI_API_KEY=<YOUR_API_KEY>
OPENAI_API_URL=<YOUR_OPENAI_API_URL>
OPENAI_MODEL=<YOUR_OPENAI_MODEL>

SYSTEM_CONTENT=<YOUR_SYSTEM_CONTENT>

DATABASE_URL=<YOUR_DATABASE_URL>

CHAT_PORT=8080

# RAG
RAG_ENABLED=false
RAG_WRITE_ENABLED=true
OPENAI_EMBEDDING_URL=https://api.openai.com/v1/embeddings
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=6

# Low-frequency memory nudge
MEMORY_NUDGE_ENABLED=true
MEMORY_NUDGE_PROB=0.20
MEMORY_NUDGE_COOLDOWN_TURNS=5
MEMORY_NUDGE_EXCLUDE_RECENT=8
MEMORY_NUDGE_MAX_CHARS=160
